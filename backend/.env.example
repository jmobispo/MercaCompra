# ================================================
# MercaCompra Backend - Environment Variables
# Copy to .env and fill in your values
# ================================================

# App
DEBUG=true
LOG_LEVEL=INFO

# Security — CHANGE THIS in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./mercacompra.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mercacompra

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Mercadona
MERCADONA_DEFAULT_POSTAL=28001

# AI mode: heuristics | local_free | claude_optional
AI_MODE=heuristics

# Claude (optional — only needed if AI_MODE=claude_optional)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-6
