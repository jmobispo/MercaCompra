# Bot environment variables
# Copy to .env

# Mercadona credentials (required for adding to cart)
MERCADONA_EMAIL=
MERCADONA_PASSWORD=

# Browser settings
HEADLESS=true
SLOW_MO=200         # milliseconds between actions
BOT_TIMEOUT=15000   # milliseconds per action

# Screenshots on error
SCREENSHOT_ON_ERROR=true
SCREENSHOTS_DIR=/tmp/mercacompra_bot
