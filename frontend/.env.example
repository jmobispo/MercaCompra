# Optional — override the backend API URL.
# Leave empty to use the Vite proxy (local dev) or nginx proxy (Docker).
# Only set this for a statically hosted frontend pointing at a remote API:
#
#   VITE_API_URL=https://api.yourdomain.com/api/v1
#
# For local network access from iPad/iPhone/Android, do NOT set this —
# keep relative URLs so the app automatically calls whatever host served the page.
# VITE_API_URL=
