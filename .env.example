# ─────────────────────────────────────────────────────────────────────────────
# MercaCompra — Root .env (used by Docker Compose)
# Copy to .env and fill in at minimum SECRET_KEY
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# App
DEBUG=false
LOG_LEVEL=INFO

# CORS: * for dev/LAN access; set to your domain in production
CORS_ORIGINS=*

# AI mode (no paid API required by default)
AI_MODE=heuristics

# Optional Claude integration
# ANTHROPIC_API_KEY=sk-ant-...

# Mercadona credentials for bot (optional — only for cart automation)
MERCADONA_EMAIL=
MERCADONA_PASSWORD=

# Bot browser settings
HEADLESS=true
SLOW_MO=200
BOT_TIMEOUT=300

# Screenshots on error
SCREENSHOT_ON_ERROR=true
